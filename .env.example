# Figma REST API token (https://www.figma.com/developers/api#access-tokens)
# Required for: composed-graphic image exports + frame image exports via
# {"figmaNodeId", "alt"} image specs. Needs `file_content:read` scope.
FIGMA_API_TOKEN=

# --- Sanity (public) ----------------------------------------------------
# These ship to the client — no secrets.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=
PUBLIC_SANITY_API_VERSION=2024-03-01
PUBLIC_SANITY_VISUAL_EDITING_ENABLED=false

# --- Sanity (server-side only) ------------------------------------------
# Read token: used by the web app for draft-preview / authenticated reads.
#   Minimum scope: "Viewer" (read only).
SANITY_API_READ_TOKEN=

# Write token: used by the seeder CLI (pnpm apply / bootstrap-page / verify)
# to upsert documents and upload image assets.
#   Minimum scope: "Editor" (write access to the dataset).
SANITY_API_WRITE_TOKEN=
