    "apply": "tsx src/cli.ts",
    "bootstrap-page": "tsx src/cli-bootstrap.ts"
  },
  "dependencies": {
    "@sanity/client": "catalog:",
    "@site-foundry/connector-core": "workspace:*",
    "@site-foundry/registry-contracts": "workspace:*",
    "@site-foundry/sanity-kit": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
